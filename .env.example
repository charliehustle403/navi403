# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# ANTHROPIC_API_KEY is optional in Milestone 1 (no model calls yet); required from Milestone 3.
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql+psycopg://navi:navi@127.0.0.1:5432/navi
# Optional: web_search degrades to "search unavailable" when unset (Tavily key by default).
SEARCH_API_KEY=
# Optional: directory of markdown notes for knowledge_base_search (default: docs)
KB_DIR=docs
